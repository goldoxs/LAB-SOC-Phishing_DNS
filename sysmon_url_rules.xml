<group name="sysmon,dns,url_monitoring">
  <!-- Ignorer les reverse DNS -->
  <rule id="100199" level="0">
    <if_group>windows</if_group>
    <field name="win.system.eventID">^22$</field>
    <field name="win.eventdata.queryName">\.in-addr\.arpa</field>
    <description>Sysmon - Reverse DNS ignoré</description>
  </rule>

  <rule id="100198" level="0">
    <if_group>windows</if_group>
    <field name="win.system.eventID">^22$</field>
    <field name="win.eventdata.queryName">\.ip6\.arpa</field>
    <description>Sysmon - Reverse DNS IPv6 ignoré</description>
  </rule>

  <!-- Règle de base : log toute requête DNS -->
  <rule id="100200" level="3">
    <if_group>windows</if_group>
    <field name="win.system.eventID">^22$</field>
    <description>Sysmon - DNS Query: $(win.eventdata.queryName)</description>
    <options>no_full_log</options>
    <group>dns_query</group>
  </rule>

  <!-- ========== WHITELIST domaines Microsoft/connus ========== -->
  <rule id="100195" level="0">
    <if_sid>87105</if_sid>
    <field name="virustotal.domain" type="pcre2">\.microsoft\.com$|\.microsoftonline\.com$|\.windows\.com$|\.windowsupdate\.com$|\.office\.com$|\.office365\.com$|\.live\.com$|\.bing\.com$|\.msn\.com$</field>
    <description>VirusTotal: Faux positif whitelist Microsoft - ignoré</description>
    <options>no_full_log</options>
  </rule>

  <!-- ========== ALERTE domaine malveillant confirmé ========== -->
  <rule id="100201" level="12">
    <if_sid>87105</if_sid>
    <description>VirusTotal: Domaine malveillant détecté: $(virustotal.domain) [$(virustotal.positives)/$(virustotal.total) moteurs]</description>
    <group>virustotal,malicious_url,</group>
    <mitre>
      <id>T1566</id>
    </mitre>
  </rule>

  <!-- ========== ALERTE domaine inconnu de VT ========== -->
  <rule id="100202" level="5">
    <if_sid>87100</if_sid>
    <field name="virustotal.error">not_found</field>
    <description>VirusTotal: Domaine inconnu de VT: $(virustotal.domain)</description>
    <group>virustotal,unknown_url,</group>
  </rule>
</group>